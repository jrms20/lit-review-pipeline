# --- LLM ---
ANTHROPIC_API_KEY="sk-ant-..."
FAST_LLM=anthropic:claude-sonnet-4-6
SMART_LLM=anthropic:claude-sonnet-4-6
STRATEGIC_LLM=anthropic:claude-sonnet-4-6
REASONING_EFFORT=medium

# --- Embeddings: Option A — OpenAI ---
OPENAI_API_KEY="sk-proj-..."
EMBEDDING=openai:text-embedding-3-small
# --- Embeddings: Option B — keyless local (no API key needed) ---
# EMBEDDING=huggingface:sentence-transformers/all-MiniLM-L6-v2

# --- Web retriever ---
TAVILY_API_KEY="tvly-..."
# (Alternative keyless fallback: change RETRIEVER below to start with duckduckgo)

# --- Retrieval / report tuning ---
RETRIEVER=tavily,arxiv,semantic_scholar
MAX_SEARCH_RESULTS_PER_QUERY=8
MAX_ITERATIONS=4
MAX_SUBTOPICS=6
CURATE_SOURCES=true
TEMPERATURE=0.2
TOTAL_WORDS=2500
REPORT_FORMAT=IEEE
