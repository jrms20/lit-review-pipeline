# Copy this file to .env and fill in the three values marked REQUIRED.
# All other settings are recommended defaults — see README.md for what each does.

# --- LLM (REQUIRED) ---
ANTHROPIC_API_KEY="sk-ant-..."
FAST_LLM=anthropic:claude-sonnet-4-6
SMART_LLM=anthropic:claude-sonnet-4-6
STRATEGIC_LLM=anthropic:claude-sonnet-4-6
REASONING_EFFORT=medium

# --- Embeddings ---
# Option A: OpenAI (REQUIRED if using Option A)
OPENAI_API_KEY="sk-proj-..."
EMBEDDING=openai:text-embedding-3-small
# Option B: keyless local embeddings (no OpenAI key needed — slower, lower quality)
# EMBEDDING=huggingface:sentence-transformers/all-MiniLM-L6-v2

# --- Web search ---
# Option A: Tavily (REQUIRED if using Option A)
TAVILY_API_KEY="tvly-..."
RETRIEVER=tavily,arxiv,semantic_scholar
# Option B: keyless fallback (lower quality, no API key needed)
# RETRIEVER=duckduckgo,arxiv,semantic_scholar

# --- Report tuning ---
MAX_SEARCH_RESULTS_PER_QUERY=8
MAX_ITERATIONS=4
MAX_SUBTOPICS=6
TOTAL_WORDS=5000
TEMPERATURE=0.2
REPORT_FORMAT=IEEE

# CURATE_SOURCES: when true, GPT Researcher applies a credibility pass that discards
# sources with blank title metadata. arXiv PDF URLs frequently arrive with no title
# when scraped, so setting this to true silently strips most arXiv content from the
# LLM context and produces short or empty reports. Keep this false.
# (The pipeline's S2 injection step re-injects arXiv abstracts from s2_corpus.json,
# which compensates — but only after you have run s2_snowball.py first.)
CURATE_SOURCES=false
